# Render Microservice Environment Variables

# Server
PORT=8001
ENVIRONMENT=development

# Auth — callers must send this as Bearer token (leave empty for dev mode = no auth)
API_KEY=dev-secret

# Queue — Layer 1 (local, no Redis needed for dev)
MAX_CONCURRENT_RENDERS=2
MAX_QUEUE_SIZE=200

# Queue — Layer 2 (uncomment to activate Redis multi-container mode)
# REDIS_URL=redis://localhost:6379/0

# AWS S3
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_BUCKET=captionit-bucket
AWS_REGION=ap-south-1
AWS_ENDPOINT_URL=http://localhost:4566    # LocalStack — leave empty for real AWS

# HMAC — must match RENDER_SERVICE_CALLBACK_HMAC_SECRET in captionit-backend/.env
CALLBACK_HMAC_SECRET=dev-hmac-secret

# Remotion project directory (absolute path)
REMOTION_DIR=/path/to/captionit-render/remotion
